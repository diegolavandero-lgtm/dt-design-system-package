  "rules": [
    "Inputs: exact DS input tokens from inputs.json — no label, placeholder only, all flex:1.",
    "Filtrar: secondary pill button — 32px height, body-small-bold font, 1px stroke, 0 16px padding.",
    "filter--add: 32×32px button, border-radius:4px, 1px border + fill var(--b6). Icon 24px (4px padding).",
    "filter--reset: 32×32px button, border-radius:4px, 1px border + fill var(--r6). Icon 24px (4px padding).",
    "Filter bar spans full card width. Inputs share width equally with flex:1. Icon buttons flex-shrink:0."
  ],
  "pageUsage": "Renderer : renderers.filters(data)\nSource   : sections/components/filters.json\n\nIn page templates:\n  Text inputs  → DS input tokens from inputs renderer (height:32px · border-radius:6px)\n  Dropdowns    → tblDemoTable structure: dt-drop-wrap / dtDrop() / dtPickOpt()\n  Filtrar btn  → secondary button inline styles (see Buttons section)\n  filter--add  → iconSvg('filter--add',  24, 'var(--b6)')  in 32×32px button\n  filter--reset→ iconSvg('filter--reset', 24, 'var(--r6)')  in 32×32px button\n\nContainer wrapping filter bar + table:\n  border-radius:8px · border:1px solid var(--n4) · background:#fff · padding:20px · gap:20px"
}
