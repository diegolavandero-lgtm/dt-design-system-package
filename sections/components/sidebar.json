{
  "title": "Sidebar",
  "titleKey": "nav.sidebar",
  "description": "Collapsed 52px icon-only / Expanded 240px icons + labels. White bg, shadow. Selected: 6px #0052CC left border + rgba(75,130,250,0.08) bg. Hover on collapsed sidebar → expands. Source: styles/packages/sidebar/src/",
  "keywords": [
    "sidebar",
    "navigation",
    "left",
    "menu",
    "collapsed",
    "expanded"
  ],
  "tokens": {
    "widthCollapsed": "52px",
    "widthExpanded": "240px",
    "bg": "#ffffff",
    "shadow": "0 6px 12px rgba(0,0,0,0.15)",
    "itemHeight": "40px",
    "iconDefault": "#4B82FA",
    "iconSelected": "#0052CC",
    "itemSelectedBg": "rgba(75,130,250,0.08)",
    "itemSelectedBorder": "#0052CC",
    "itemHoverBg": "rgba(75,130,250,0.04)",
    "separatorColor": "#E9ECF2"
  },
  "mobileTokens": {
    "trigger": "Hamburger icon en topbar (24×24px)",
    "drawerWidth": "280px",
    "drawerMaxWidth": "85vw",
    "itemHeight": "48px",
    "iconSize": "20px",
    "labelSize": "15px",
    "overlayBg": "rgba(19,32,69,0.5)",
    "transition": "transform .25s cubic-bezier(.4,0,.2,1)",
    "headerHeight": "56px",
    "note": "Sidebar oculto por defecto. Hamburger icon abre drawer desde la izquierda con overlay. Altura de items 48px (touch target). Labels siempre visibles, sin estado collapsed."
  },
