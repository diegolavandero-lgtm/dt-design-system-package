{
  "title": "Tables",
  "titleKey": "nav.table",
  "description": "Data tables for structured content. Cell height 44px. Header on N3. White row bg. Hover → N2. Selected → B1 with G5 left stripe. Actions column is sticky at the right edge.",
  "keywords": ["table", "rows", "hover", "selected", "columns", "cells", "badge", "avatar", "link", "actions", "switch", "rating", "chip", "skeleton"],
  "tokens": {
    "cellHeight":      "44px",
    "headerHeight":    "40px",
    "headerBg":        "#E1E6ED  (N3)",
    "rowBg":           "#FFFFFF",
    "rowHoverBg":      "#F0F2F5  (N2)",
    "rowSelectedBg":   "#EDF5FF  (B1)",
    "selectedStripe":  "#36B37E  (G5)  ·  3px inset-left",
    "divider":         "#E1E6ED  (N3)",
    "borderRadius":    "8px",
    "fontSize":        "13px",
    "fontWeightRow":   "400",
    "fontWeightHeader":"700"
  },
  "rowTypes": [
    {
      "id": "header",
      "label": "Header",
      "bg": "#E1E6ED",
      "description": "Column headers. Background N3. Font 700 13px. Optional sort caret."
    },
    {
      "id": "default",
      "label": "Default",
      "bg": "#FFFFFF",
      "description": "Standard data row. White background. Font 400 13px."
    },
    {
      "id": "hover",
      "label": "Hover",
      "bg": "#F0F2F5",
      "description": "Row on mouseenter. Background N2."
    },
    {
      "id": "selected",
      "label": "Selected",
      "bg": "#EDF5FF",
      "stripeColor": "#36B37E",
      "description": "Active selection. Background B1 + 3px G5 left stripe. Checkbox checked."
    },
    {
      "id": "disabled",
      "label": "Disabled",
      "bg": "#FFFFFF",
      "opacity": "40%",
      "description": "Non-interactive row. All content at 40% opacity. pointer-events: none."
    }
  ],
  "cellTypes": [
    { "id": "checkbox",        "label": "Checkbox",              "description": "Row selection. 14px, accent-color B5." },
    { "id": "header",          "label": "Header cell",           "description": "Column label. Bold, bg N3. Sortable variant adds sort caret." },
    { "id": "header-sub",      "label": "Header + subtext",      "description": "Header with small gray category text above the column name." },
    { "id": "text",            "label": "Text",                  "description": "Plain text. Color N7. Font 400 13px." },
    { "id": "text-secondary",  "label": "Text secondary",        "description": "Muted text. Color N5. Used for — placeholders." },
    { "id": "icon-text",       "label": "Icon left + text",      "description": "14px icon on the left + label. Used for locations, categories." },
    { "id": "text-icon-right", "label": "Text + icon right",     "description": "Label + 14px icon on the right. Used for external links, expand actions." },
    { "id": "text-sub",        "label": "Text + sub",            "description": "Primary text + smaller gray subtext below. Two-line cell." },
    { "id": "text-error",      "label": "Text + error",          "description": "Primary text + red error subtext below." },
    { "id": "text-icon-error", "label": "Icon + text + error",   "description": "Left icon + primary text + red error subtext below." },
    { "id": "link",            "label": "Link",                  "description": "Clickable text. Color B7, font-weight 600." },
    { "id": "badge",           "label": "Badge / Pill",          "description": "Status badge. Variants: success, warning, danger, info, neutral.",
      "badgeVariants": [
        { "label": "Activo",      "variant": "success" },
        { "label": "Advertencia", "variant": "warning" },
        { "label": "Bloqueado",   "variant": "danger"  },
        { "label": "Info",        "variant": "info"    },
        { "label": "Inactivo",    "variant": "neutral" }
      ]
    },
    { "id": "avatar-text",     "label": "Avatar + text",         "description": "28px filled circle with initials + name." },
    { "id": "date",            "label": "Date",                  "description": "Formatted date string. Format: DD-MM-YY HH:MM hrs." },
    { "id": "number",          "label": "Number",                "description": "Right-aligned numeric. Font tabular-nums." },
    { "id": "rating",          "label": "Rating stars",          "description": "1–5 interactive star rating. Click to set." },
    { "id": "switch",          "label": "Switch",                "description": "Toggle switch. Click to toggle on/off." },
    { "id": "switch-text",     "label": "Switch + text",         "description": "Toggle switch with inline text label." },
    { "id": "chip-lg",         "label": "Chip large",            "description": "Generic large chip tag. Background N2, border N3." },
    { "id": "chip-sm",         "label": "Chip small",            "description": "Generic small chip tag. Compact padding, 11px font." },
    { "id": "pill-new",        "label": "Pill · New",            "description": "Blue NEW pill indicator. Uppercase 9px, B1 bg." },
    { "id": "loading-bar",     "label": "Loading bar",           "description": "Horizontal progress bar with percentage label. Value 0–100." },
    { "id": "lazy",            "label": "Lazy load",             "description": "Skeleton shimmer for both header and data cells while loading." },
    { "id": "actions",         "label": "Actions",               "description": "Max 2 icon-only action buttons. Sticky at the right edge of the table." }
  ],
  "columnTypeMap": {
    "checkbox":        ["", "☐", "select", "check", "seleccionar"],
    "avatar-text":     ["nombre", "name", "driver", "conductor", "operador", "user", "usuario", "cliente", "customer"],
    "icon-text":       ["dirección", "address", "origen", "destino", "origin", "destination", "ubicación", "location"],
    "link":            ["#", "id", "orden", "order", "pedido", "ruta", "route", "folio", "código", "code"],
    "badge":           ["estado", "status", "state", "prioridad", "priority", "tipo", "type"],
    "date":            ["fecha", "date", "created_at", "updated_at", "última", "last", "hora", "time", "conexión", "entrega"],
    "number":          ["cantidad", "qty", "count", "total", "km", "stops", "paradas", "distance", "distancia", "bultos"],
    "switch":          ["activo", "active", "enabled", "habilitado", "toggle"],
    "rating":          ["rating", "calificación", "score", "puntuación", "stars"],
    "loading-bar":     ["progreso", "progress", "completion", "completado", "%"],
    "actions":         ["acciones", "actions", "opciones", "options", "…", "more"]
  },
