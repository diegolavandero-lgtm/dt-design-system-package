{
  "title": "Tables",
  "titleKey": "nav.table",
  "description": "Data tables for structured content. Cell height 44px. Header on N3. White row bg. Hover → N2. Selected → B1 with G5 left stripe. Checkbox selection column optional.",
  "keywords": ["table", "rows", "hover", "selected", "columns", "cells", "badge", "avatar", "link", "actions"],
  "tokens": {
    "cellHeight":      "44px",
    "headerHeight":    "40px",
    "headerBg":        "#E1E6ED  (N3)",
    "rowBg":           "#FFFFFF",
    "rowHoverBg":      "#F0F2F5  (N2)",
    "rowSelectedBg":   "#EDF5FF  (B1)",
    "selectedStripe":  "#36B37E  (G5)  ·  3px inset-left",
    "divider":         "#E1E6ED  (N3)",
    "borderRadius":    "8px",
    "fontSize":        "13px",
    "fontWeightRow":   "400",
    "fontWeightHeader":"700"
  },
  "rowTypes": [
    {
      "id": "header",
      "label": "Header",
      "bg": "#E1E6ED",
      "description": "Column headers. Background N3. Font 700 13px. Optional sort caret."
    },
    {
      "id": "default",
      "label": "Default",
      "bg": "#FFFFFF",
      "description": "Standard data row. White background. Font 400 13px."
    },
    {
      "id": "hover",
      "label": "Hover",
      "bg": "#F0F2F5",
      "description": "Row on mouseenter. Background N2 (#F0F2F5)."
    },
    {
      "id": "selected",
      "label": "Selected",
      "bg": "#EDF5FF",
      "stripeColor": "#36B37E",
      "description": "Active selection. Background B1 + 3px G5 left stripe. Checkbox checked."
    },
    {
      "id": "disabled",
      "label": "Disabled",
      "bg": "#FFFFFF",
      "opacity": "40%",
      "description": "Non-interactive row. All content at 40% opacity. pointer-events: none."
    }
  ],
  "cellTypes": [
    {
      "id": "checkbox",
      "label": "Checkbox",
      "element": "td",
      "width": "40px",
      "description": "Row selection. 14px checkbox, accent-color B5.",
      "example": { "type": "checkbox", "value": false }
    },
    {
      "id": "header",
      "label": "Header cell",
      "element": "th",
      "description": "Column label. Bold, bg N3. Sortable variant adds caret icon.",
      "example": { "type": "header", "value": "Column name" }
    },
    {
      "id": "text",
      "label": "Text",
      "element": "td",
      "description": "Plain text. Color N7. Font 400 13px.",
      "example": { "type": "text", "value": "Admin Master" }
    },
    {
      "id": "text-secondary",
      "label": "Text secondary",
      "element": "td",
      "description": "Muted/empty text. Color N5. Used for — placeholders and secondary values.",
      "example": { "type": "text-secondary", "value": "—" }
    },
    {
      "id": "text-icon",
      "label": "Text + icon",
      "element": "td",
      "description": "14px leading icon + label. Used for locations, roles, categories.",
      "example": { "type": "text-icon", "icon": "location", "value": "Av. Principal 123" }
    },
    {
      "id": "link",
      "label": "Link",
      "element": "td",
      "description": "Clickable text. Color B7, font-weight 600.",
      "example": { "type": "link", "value": "#ORD-4821" }
    },
    {
      "id": "badge",
      "label": "Badge / Pill",
      "element": "td",
      "description": "Status indicator. Variants: success, warning, danger, info, neutral.",
      "badgeVariants": [
        { "label": "Activo",      "variant": "success" },
        { "label": "Advertencia", "variant": "warning" },
        { "label": "Bloqueado",   "variant": "danger"  },
        { "label": "Info",        "variant": "info"    },
        { "label": "Inactivo",    "variant": "neutral" }
      ],
      "example": { "type": "badge", "value": "Activo", "variant": "success" }
    },
    {
      "id": "avatar-text",
      "label": "Avatar + text",
      "element": "td",
      "description": "28px filled circle with initials + name. Circle color assigned per user.",
      "example": { "type": "avatar-text", "value": "Maya Johnson", "initials": "MJ", "color": "#1F60ED" }
    },
    {
      "id": "date",
      "label": "Date",
      "element": "td",
      "description": "Formatted date string. Format: DD-MM-YY HH:MM hrs.",
      "example": { "type": "date", "value": "10-10-25 10:35 hrs" }
    },
    {
      "id": "number",
      "label": "Number",
      "element": "td",
      "description": "Right-aligned numeric value. Font tabular-nums.",
      "example": { "type": "number", "value": "1,240" }
    },
    {
      "id": "actions",
      "label": "Actions",
      "element": "td",
      "description": "Icon-only action buttons. Most common: edit + delete. Right-aligned.",
      "example": { "type": "actions", "value": ["edit", "delete"] }
    }
  ],
  "columnTypeMap": {
    "checkbox":     ["", "☐", "select", "check", "seleccionar"],
    "avatar-text":  ["nombre", "name", "driver", "conductor", "operador", "user", "usuario", "cliente", "customer"],
    "text-icon":    ["dirección", "address", "origen", "destino", "origin", "destination", "ubicación", "location"],
    "link":         ["#", "id", "orden", "order", "pedido", "ruta", "route", "folio", "código", "code"],
    "badge":        ["estado", "status", "state", "prioridad", "priority", "tipo", "type"],
    "date":         ["fecha", "date", "created_at", "updated_at", "última", "last", "hora", "time", "conexión", "entrega", "delivery"],
    "number":       ["cantidad", "qty", "count", "total", "km", "stops", "paradas", "distance", "distancia", "bultos", "piezas"],
    "actions":      ["acciones", "actions", "opciones", "options", "…", "more"]
  },
