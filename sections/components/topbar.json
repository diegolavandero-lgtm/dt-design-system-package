{
  "title": "Topbar",
  "titleKey": "nav.topbar",
  "description": "Height 52px ($hp-top-bar-height), bg $hp-dt-indigo (#132045). Customer slot 100px, border-radius 25px 0 0 0. Icon order invariable: apps · alerts · messages · help · settings · user. Source: styles/packages/top-bar/src/",
  "keywords": [
    "topbar",
    "header",
    "navigation",
    "top",
    "bar"
  ],
  "tokens": {
    "height": "52px",
    "bg": "#132045",
    "ink": "#fff",
    "customerWidth": "100px",
    "customerRadius": "25px 0 0 0",
    "productColors": {
      "lastmile": "#F27B42",
      "firstmile": "#FF3E50",
      "planner": "#47D09A",
      "ondemand": "#6B9AFF"
    }
  },
  "iconOrder": [
    "apps",
    "alerts",
    "messages",
    "help",
    "settings",
    "user"
  ],
  "breakpoints": {
    "desktop": "≥1024px — full logo + all 6 icons + customer slot",
    "tablet": "768–1023px — full logo + 3 icons (alerts, messages, user) + customer slot abbreviated",
    "mobile": "<768px — mobile logo (icon only) + 2 icons (alerts, user) + no customer slot"
  },
